#################################################################################################################################################################
########### Import                                                                                                                                     [ Import ]
##### Internal                                                                                                                               [ Import, Internal ]
##### External                                                                                                                               [ Import, External ]
load("@vantle//component/generation/starlark:defs.bzl", "extract", "rust_autotest_function")

##### Visibility                                                                                                                                       [ Module ]
package(default_visibility = [
    "//Molten/test:__pkg__",
    "//Molten/test:__subpackages__",
])

##### Module                                                                                                                                           [ Module ]
rust_autotest_function(
    name = "particle",
    cases = "//Molten/test/resource/component/graph/state/particle:cases",
    template = "//Molten/test/resource/component/graph/state/particle:template",
    deps = [
        "//Molten:component",
    ],
)

extract(
    name = "function.document",
    language = "starlark",
    query = "(call function: (identifier) @name (#eq? @name \"rust_autotest_function\")) @capture",
    source = "BUILD.bazel",
    visibility = ["//visibility:public"],
)

