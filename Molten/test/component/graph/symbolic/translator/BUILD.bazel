#################################################################################################################################################################
########### Import                                                                                                                                     [ Import ]
##### Internal                                                                                                                               [ Import, Internal ]
##### External                                                                                                                               [ Import, External ]
load("//component/generation/starlark:defs.bzl", "autotest_document", "rust_autotest_function")

##### Visibility                                                                                                                                       [ Module ]
package(default_visibility = [
    "//Molten/test:__pkg__",
    "//Molten/test:__subpackages__",
])

##### Module                                                                                                                                           [ Module ]
rust_autotest_function(
    name = "translator",
    testonly = False,
    cases = "//Molten/test/resource/component/graph/symbolic/translator:cases",
    template = "//Molten/test/resource/component/graph/symbolic/translator:template",
    deps = [
        "//component:translator",
    ],
)

##### Documentation                                                                                                                             [ Documentation ]
autotest_document(
    name = "translator.component.document",
    test = ":translator",
    template = "//Molten/test/resource/component/graph/symbolic/translator:template",
    visibility = ["//visibility:public"],
)
