#################################################################################################################################################################
########### Import                                                                                                                                     [ Import ]
##### Internal                                                                                                                               [ Import, Internal ]
load("@vantle//component/generation/starlark:defs.bzl", "extract", "rust_autotest_template")
##### External                                                                                                                               [ Import, External ]

##### Visibility                                                                                                                                       [ Module ]
package(default_visibility = [
    "//Molten/test:__pkg__",
    "//Molten/test:__subpackages__",
])

##### Module                                                                                                                                           [ Module ]

filegroup(
    name = "cases",
    srcs = ["cases.json"],
    visibility = ["//visibility:public"],
)

filegroup(
    name = "data",
    srcs = [
        "particle.template.rs",
        ":cases",
    ],
)

rust_autotest_template(
    name = "template",
    src = "particle.template.rs",
    deps = [
        "//Molten:component",
        "//Molten:system",
        "//Molten/system/graph/symbolic:constructor",
    ],
)

extract(
    name = "disjoint",
    language = "rust",
    query = "(function_item name: (identifier) @name (#eq? @name \"disjoint\")) @capture",
    source = "particle.template.rs",
    visibility = ["//visibility:public"],
)

extract(
    name = "particle.cases.json",
    language = "json",
    query = "(document) @capture",
    source = "cases.json",
    visibility = ["//visibility:public"],
)

extract(
    name = "template.document",
    language = "starlark",
    query = "(call function: (identifier) @name (#eq? @name \"rust_autotest_template\")) @capture",
    source = "BUILD.bazel",
    visibility = ["//visibility:public"],
)

##### Documentation                                                                                                                             [ Documentation ]
