    data = [
        "//Molten/test/resource/component/graph/attribute:data",
    ],
    template = "//Molten/test/resource/system/graph/breadth/generate:template",
    deps = [
        "//Molten/component:module",
        "//Molten/system/graph/symbolic:module",
        "//test/utility:module",
    ],
)

rust_autotest(
    name = "constructor",
    cases = "//Molten/test/resource/system/graph/constructor/generate:cases",
    template = "//Molten/test/resource/system/graph/constructor/generate:template",
    deps = [
        "//Molten/component:module",
        "//Molten/system:module",
    ],
)

