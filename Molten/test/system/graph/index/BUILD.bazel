#################################################################################################################################################################
########### Import                                                                                                                                     [ Import ]
##### Internal                                                                                                                               [ Import, Internal ]
##### External                                                                                                                               [ Import, External ]
load("//component/generation/starlark:defs.bzl", "autotest_document", "rust_autotest_function")

##### Visibility                                                                                                                                       [ Module ]
package(default_visibility = [
    "//Molten/test:__pkg__",
    "//Molten/test:__subpackages__",
])

##### Module                                                                                                                                           [ Module ]
rust_autotest_function(
    name = "index",
    testonly = False,
    cases = "//Molten/test/resource/system/graph/index:cases",
    template = "//Molten/test/resource/system/graph/index:template",
    deps = [
        "//Molten:component",
        "//Molten:system",
        "//Molten/system/graph:index",
        "//test:utility",
    ],
)

##### Documentation                                                                                                                             [ Documentation ]
autotest_document(
    name = "index.document",
    test = ":index",
    template = "//Molten/test/resource/system/graph/index:template",
    visibility = ["//visibility:public"],
)
