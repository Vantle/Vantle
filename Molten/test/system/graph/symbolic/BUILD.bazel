#################################################################################################################################################################
########### Import                                                                                                                                     [ Import ]
##### Internal                                                                                                                               [ Import, Internal ]
##### External                                                                                                                               [ Import, External ]
load("//component/generation/starlark:defs.bzl", "autotest_document", "rust_autotest_function")

##### Visibility                                                                                                                                       [ Module ]
package(default_visibility = [
    "//Molten/test:__pkg__",
    "//Molten/test:__subpackages__",
])

##### Module                                                                                                                                           [ Module ]
rust_autotest_function(
    name = "translator",
    testonly = False,
    aliases = {
        "//system/translator:consume": "ingest",
        "//system/translator:view": "inspect",
    },
    cases = "//Molten/test/resource/system/graph/symbolic/translator:cases",
    template = "//Molten/test/resource/system/graph/symbolic/translator:template",
    deps = [
        "//component:translator",
        "//component/translator:rule",
        "//system/translator:consume",
        "//system/translator:view",
        "//test:utility",
    ],
)

rust_autotest_function(
    name = "renderer",
    testonly = False,
    aliases = {
        "//Molten/component:arena": "valued",
    },
    cases = "//Molten/test/resource/system/graph/symbolic/renderer:cases",
    data = ["//Molten/test/resource/system/graph/module:data"],
    template = "//Molten/test/resource/system/graph/symbolic/renderer:template",
    deps = [
        "//Molten:component",
        "//Molten:system",
        "//Molten/component:arena",
        "//Molten/system/graph:attribute",
        "//Molten/system/graph:symbolic",
        "//test:utility",
    ],
)

##### Documentation                                                                                                                             [ Documentation ]
autotest_document(
    name = "translator.symbolic.document",
    test = ":translator",
    template = "//Molten/test/resource/system/graph/symbolic/translator:template",
    visibility = ["//visibility:public"],
)

autotest_document(
    name = "renderer.document",
    test = ":renderer",
    template = "//Molten/test/resource/system/graph/symbolic/renderer:template",
    visibility = ["//visibility:public"],
)
