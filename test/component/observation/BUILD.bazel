#################################################################################################################################################################
########### Import                                                                                                                                     [ Import ]
##### Internal                                                                                                                               [ Import, Internal ]
load("//component/generation/starlark:defs.bzl", "autotest_document", "rust_autotest_function")
##### External                                                                                                                               [ Import, External ]

##### Visibility                                                                                                                                       [ Module ]
package(default_visibility = [
    "//test/component/observation:__pkg__",
    "//test/component/observation:__subpackages__",
])

##### Module                                                                                                                                           [ Module ]
rust_autotest_function(
    name = "observation",
    testonly = False,
    cases = "//test/resource/component/observation:cases",
    template = "//test/resource/component/observation:template",
    deps = [
        "//component/observation:layer",
        "//component/observation:stream",
        "//system:observation",
        "@crates//:tracing",
    ],
)

rust_autotest_function(
    name = "lifecycle",
    testonly = False,
    cases = "//test/resource/component/observation/lifecycle:cases",
    template = "//test/resource/component/observation/lifecycle:template",
    deps = [
        "//component/observation:layer",
        "//component/observation:stream",
        "//system:observation",
        "@crates//:tracing",
    ],
)

rust_autotest_function(
    name = "channel",
    testonly = False,
    cases = "//test/resource/component/observation/channel:cases",
    template = "//test/resource/component/observation/channel:template",
    deps = [
        "//component/observation:channel",
    ],
)

rust_autotest_function(
    name = "expression",
    testonly = False,
    aliases = {"//component/observation:expression": "filterable"},
    cases = "//test/resource/component/observation/expression:cases",
    template = "//test/resource/component/observation/expression:template",
    deps = [
        "//component/observation:channel",
        "//component/observation:expression",
        "//component/tag:expression",
        "//component/observation/expression:parse",
    ],
)

##### Documentation                                                                                                                             [ Documentation ]
autotest_document(
    name = "observation.document",
    test = ":observation",
    template = "//test/resource/component/observation:template",
    visibility = ["//visibility:public"],
)

autotest_document(
    name = "lifecycle.document",
    test = ":lifecycle",
    template = "//test/resource/component/observation/lifecycle:template",
    visibility = ["//visibility:public"],
)

autotest_document(
    name = "channel.document",
    test = ":channel",
    template = "//test/resource/component/observation/channel:template",
    visibility = ["//visibility:public"],
)

autotest_document(
    name = "expression.observation.document",
    test = ":expression",
    template = "//test/resource/component/observation/expression:template",
    visibility = ["//visibility:public"],
)
