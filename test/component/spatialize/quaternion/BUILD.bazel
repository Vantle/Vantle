#################################################################################################################################################################
########### Import                                                                                                                                     [ Import ]
##### Internal                                                                                                                               [ Import, Internal ]
##### External                                                                                                                               [ Import, External ]
load("//component/generation/starlark:defs.bzl", "autotest_document", "rust_autotest_function")

##### Visibility                                                                                                                                       [ Module ]
package(default_visibility = [
    "//test:__pkg__",
    "//test:__subpackages__",
])

##### Module                                                                                                                                           [ Module ]
rust_autotest_function(
    name = "quaternion",
    testonly = False,
    cases = "//test/resource/component/spatialize/quaternion:cases",
    template = "//test/resource/component/spatialize/quaternion:template",
    deps = [
        "//component/spatialize:quaternion",
        "//component/spatialize:vector",
    ],
)

##### Documentation                                                                                                                             [ Documentation ]
autotest_document(
    name = "quaternion.document",
    test = ":quaternion",
    template = "//test/resource/component/spatialize/quaternion:template",
    visibility = ["//visibility:public"],
)
