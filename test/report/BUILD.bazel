#################################################################################################################################################################
########### Import                                                                                                                                     [ Import ]
##### External                                                                                                                               [ Import, External ]
load("@rules_rust//rust:defs.bzl", "rust_library")

##### Visibility                                                                                                                                       [ Module ]
package(default_visibility = [
    "//test:__pkg__",
])

##### Module                                                                                                                                           [ Module ]
rust_library(
    name = "error",
    srcs = ["error.rs"],
    deps = [
        "//system/generation/runtime:runtime",
        "@crates//:miette",
        "@crates//:serde_json",
        "@crates//:thiserror",
    ],
)

rust_library(
    name = "execution",
    srcs = ["execution.rs"],
    deps = [
        "//test/report:error",
        "@crates//:serde",
        "@crates//:serde_json",
    ],
)
