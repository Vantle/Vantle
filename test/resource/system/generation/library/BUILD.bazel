##### External                                                                                                                               [ Import, External ]
load("@rules_rust//rust:defs.bzl", "rust_library")

#################################################################################################################################################################
########### Import                                                                                                                                     [ Import ]
##### Internal                                                                                                                               [ Import, Internal ]
load("@vantle//component/generation/starlark:defs.bzl", "rust_autotest_template")

##### Visibility                                                                                                                                       [ Module ]
package(default_visibility = [
    "//test:__pkg__",
    "//test:__subpackages__",
])

##### Module                                                                                                                                           [ Module ]
rust_library(
    name = "module",
    srcs = ["library.rs"],
    crate_name = "library",
)

filegroup(
    name = "cases",
    srcs = ["cases.json"],
)

rust_autotest_template(
    name = "template",
    src = "composition.rs",
    deps = [
        ":module",
    ],
)

filegroup(
    name = "data",
    srcs = [
        "cases.json",
        "composition.rs",
        "library.rs",
    ],
)

##### Documentation                                                                                                                             [ Documentation ]
