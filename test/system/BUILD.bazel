#################################################################################################################################################################
########### Import                                                                                                                                     [ Import ]
##### Internal                                                                                                                               [ Import, Internal ]
##### External                                                                                                                               [ Import, External ]
load("@rules_rust//rust:defs.bzl", "rust_library")

##### Visibility                                                                                                                                       [ Module ]
package(default_visibility = [
    "//test:__pkg__",
    "//test:__subpackages__",
])

##### Module                                                                                                                                           [ Module ]
rust_library(
    name = "function",
    srcs = ["function.rs"],
    proc_macro_deps = ["//system/observation:macro"],
    visibility = [
        "//:__pkg__",
        "//:__subpackages__",
    ],
    deps = [
        "//component/observation:channel",
        "//component/observation:module",
        "//platform:test",
        "//system:concurrent",
        "//system/observation:argument",
        "//test/system/function:error",
        "//test/system/function:execution",
        "@crates//:clap",
        "@crates//:derive_more",
        "@crates//:miette",
        "@crates//:serde",
        "@crates//:serde_json",
        "@crates//:tracing",
    ],
)

rust_library(
    name = "performance",
    srcs = ["performance.rs"],
    visibility = [
        "//:__pkg__",
        "//:__subpackages__",
    ],
    deps = [
        "//:component",
        "//component/generation/rust:performance",
        "//component/math:regression",
        "//platform:test",
        "//system:concurrent",
        "//system/observation:argument",
        "//test/system/performance:error",
        "@crates//:clap",
        "@crates//:miette",
        "@crates//:serde",
        "@crates//:serde_json",
    ],
)

