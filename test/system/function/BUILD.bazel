#################################################################################################################################################################
########### Import                                                                                                                                     [ Import ]
##### External                                                                                                                               [ Import, External ]
load("@rules_rust//rust:defs.bzl", "rust_library")
load("//component/generation/starlark:defs.bzl", "extract")

##### Visibility                                                                                                                                       [ Module ]
package(default_visibility = [
    "//:__pkg__",
    "//:__subpackages__",
])

##### Module                                                                                                                                           [ Module ]
rust_library(
    name = "error",
    srcs = ["error.rs"],
    deps = [
        "//system/generation/runtime",
        "@crates//:miette",
        "@crates//:serde_json",
        "@crates//:thiserror",
    ],
)

rust_library(
    name = "execution",
    srcs = ["execution.rs"],
    deps = [
        "//test/system/function:error",
        "@crates//:serde",
        "@crates//:serde_json",
    ],
)

##### Extraction                                                                                                                               [ Extraction ]
extract(
    name = "execution.schema",
    language = "rust",
    query = "(struct_item) @capture",
    source = "execution.rs",
    visibility = ["//visibility:public"],
)

