#################################################################################################################################################################
########### Import                                                                                                                                     [ Import ]
##### External                                                                                                                               [ Import, External ]
load("@rules_rust//rust:defs.bzl", "rust_library")

##### Visibility                                                                                                                                       [ Module ]
package(default_visibility = [
    "//:__pkg__",
    "//:__subpackages__",
])

##### Module                                                                                                                                           [ Module ]
rust_library(
    name = "error",
    srcs = ["error.rs"],
    deps = [
        "//system/generation/runtime",
        "@crates//:miette",
        "@crates//:serde_json",
        "@crates//:thiserror",
    ],
)

rust_library(
    name = "execution",
    srcs = ["execution.rs"],
    deps = [
        "//test/system/function:error",
        "@crates//:serde",
        "@crates//:serde_json",
    ],
)

rust_library(
    name = "function",
    srcs = ["report.rs"],
    proc_macro_deps = ["//system/observation:macro"],
    deps = [
        "//component/observation:channel",
        "//component/observation:module",
        "//platform:test",
        "//system:concurrent",
        "//system/observation:argument",
        "//test/system/function:error",
        "//test/system/function:execution",
        "@crates//:clap",
        "@crates//:derive_more",
        "@crates//:miette",
        "@crates//:serde",
        "@crates//:serde_json",
        "@crates//:tracing",
    ],
)
