#################################################################################################################################################################
########### Import                                                                                                                                     [ Import ]
##### Internal                                                                                                                               [ Import, Internal ]
load("//component/generation/starlark:defs.bzl", "autotest_document", "rust_autotest_function")
##### External                                                                                                                               [ Import, External ]

##### Visibility                                                                                                                                       [ Module ]
package(default_visibility = [
    "//test/system/observation:__pkg__",
    "//test/system/observation:__subpackages__",
])

##### Module                                                                                                                                           [ Module ]
rust_autotest_function(
    name = "level",
    testonly = False,
    cases = "//test/resource/system/observation/level:cases",
    template = "//test/resource/system/observation/level:template",
    deps = [
        "//component/observation:layer",
        "//component/observation:stream",
        "//system:observation",
        "@crates//:tracing",
    ],
)

rust_autotest_function(
    name = "span",
    testonly = False,
    cases = "//test/resource/system/observation/span:cases",
    template = "//test/resource/system/observation/span:template",
    deps = [
        "//component/observation:layer",
        "//component/observation:stream",
        "//system:observation",
        "@crates//:tracing",
    ],
)

rust_autotest_function(
    name = "hierarchy",
    testonly = False,
    cases = "//test/resource/system/observation/hierarchy:cases",
    template = "//test/resource/system/observation/hierarchy:template",
    deps = [
        "//component/observation:layer",
        "//component/observation:stream",
        "//system:observation",
        "@crates//:tracing",
    ],
)

rust_autotest_function(
    name = "filtering",
    testonly = False,
    cases = "//test/resource/system/observation/filtering:cases",
    template = "//test/resource/system/observation/filtering:template",
    deps = [
        "//component/observation:channel",
        "//component/observation:layer",
        "//component/observation:stream",
        "//system:observation",
        "@crates//:tracing",
    ],
)

rust_autotest_function(
    name = "peer",
    testonly = False,
    cases = "//test/resource/system/observation/peer:cases",
    template = "//test/resource/system/observation/peer:template",
    deps = [
        "//component:assemble",
        "//system/observation:peer",
        "@crates//:url",
    ],
)

##### Documentation                                                                                                                             [ Documentation ]
autotest_document(
    name = "level.document",
    test = ":level",
    template = "//test/resource/system/observation/level:template",
    visibility = ["//visibility:public"],
)

autotest_document(
    name = "span.document",
    test = ":span",
    template = "//test/resource/system/observation/span:template",
    visibility = ["//visibility:public"],
)

autotest_document(
    name = "hierarchy.document",
    test = ":hierarchy",
    template = "//test/resource/system/observation/hierarchy:template",
    visibility = ["//visibility:public"],
)

autotest_document(
    name = "filtering.document",
    test = ":filtering",
    template = "//test/resource/system/observation/filtering:template",
    visibility = ["//visibility:public"],
)

autotest_document(
    name = "peer.document",
    test = ":peer",
    template = "//test/resource/system/observation/peer:template",
    visibility = ["//visibility:public"],
)
