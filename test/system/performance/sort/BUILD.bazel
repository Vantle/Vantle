#################################################################################################################################################################
########### Import                                                                                                                                     [ Import ]
##### Internal                                                                                                                               [ Import, Internal ]
##### External                                                                                                                               [ Import, External ]
load("//component/generation/starlark:defs.bzl", "execute", "extract", "rust_autotest_performance")

##### Visibility                                                                                                                                       [ Module ]
package(default_visibility = [
    "//test:__pkg__",
    "//test:__subpackages__",
])

##### Module                                                                                                                                           [ Module ]
rust_autotest_performance(
    name = "sort",
    size = "medium",
    testonly = False,
    cases = "//test/resource/system/performance/sort:cases",
    specification = "//test/resource/system/performance/sort:performance",
    template = "//test/resource/system/performance/sort:template",
)

execute(
    name = "sort.execute",
    binary = ":sort.binary",
    output = "sort.execution.json",
    parameters = {
        "bound": "on",
        "interval": "on",
        "model": "on",
        "sample": "off",
    },
)

extract(
    name = "execution.schema",
    language = "json",
    source = ":sort.execute",
    visibility = ["//visibility:public"],
)

extract(
    name = "performance.document",
    language = "starlark",
    query = "(call function: (identifier) @name (#eq? @name \"rust_autotest_performance\")) @capture",
    source = "BUILD.bazel",
    visibility = ["//visibility:public"],
)

##### Documentation                                                                                                                             [ Documentation ]
